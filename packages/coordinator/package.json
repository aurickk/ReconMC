{
  "name": "@reconmc/coordinator",
  "version": "1.0.0",
  "description": "Coordination server for parallel recon agents",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "dev": "tsx watch src/index.ts",
    "start": "node dist/index.js",
    "test": "node --import tsx --test src/__tests__/*.test.ts",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:push": "drizzle-kit push"
  },
  "dependencies": {
    "@fastify/compress": "^8.0.0",
    "@fastify/cors": "^11.2.0",
    "@reconmc/scanner": "*",
    "drizzle-orm": "^0.45.2",
    "fastify": "^5.7.4",
    "ioredis": "^5.4.1",
    "ip-cidr": "^4.0.2",
    "pg": "^8.13.1"
  },
  "devDependencies": {
    "@types/node": "^25.5.2",
    "@types/pg": "^8.11.0",
    "drizzle-kit": "^0.31.10",
    "tsx": "^4.19.0",
    "typescript": "^6.0.2"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
