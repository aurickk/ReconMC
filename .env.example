# ReconMC Configuration
# Copy to .env and configure

# PostgreSQL (required)
POSTGRES_PASSWORD=change_this_secure_password

# API authentication (optional)
# RECONMC_API_KEY=
# RECONMC_DISABLE_AUTH=false

# Trusted networks for internal endpoints (comma-separated CIDR)
# Agent routes (register, heartbeat, claim, complete, fail, tokens) are only
# accessible from these networks. Default: Docker internal ranges + localhost
# Examples:
#   - Localhost only: 127.0.0.0/8
#   - With LAN access: 127.0.0.0/8,172.16.0.0/12,10.0.0.0/8,192.168.0.0/16
#   - With Tailscale: 127.0.0.0/8,172.16.0.0/12,10.0.0.0/8,100.64.0.0/10
# TRUSTED_NETWORKS=

# CORS origins (comma-separated, or * for all)
# CORS_ORIGINS=

# Agent replicas (default: 3)
# AGENT_COUNT=3

# Debug logging
# MC_DEBUG=false
# LOG_LEVEL=info

# Override internal settings (usually not needed)
# PORT=3000
# HOST=0.0.0.0
# DATABASE_URL=
# REDIS_URL=
