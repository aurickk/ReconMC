# =============================================================================
# ReconMC Environment Configuration (Docker Compose)
# =============================================================================
# Copy this file to .env and fill in the required values
# This setup is for running the entire stack with Docker Compose only

# -----------------------------------------------------------------------------
# Coordinator Configuration
# -----------------------------------------------------------------------------
PORT=3000
HOST=0.0.0.0
# Internal port and bind address (used inside containers)
# Docker Compose maps external port 3001 to this port

# -----------------------------------------------------------------------------
# Authentication (recommended for production)
# -----------------------------------------------------------------------------
# API Key for external API access (web dashboard, Discord bot, external tools)
# Generate with: openssl rand -hex 32
# RECONMC_API_KEY=

# Disable API key authentication (development only)
# WARNING: Never enable in production!
# RECONMC_DISABLE_AUTH=false

# -----------------------------------------------------------------------------
# CORS (Cross-Origin Resource Sharing)
# -----------------------------------------------------------------------------
# Comma-separated list of allowed origins for web dashboard access
# Example: https://dashboard.example.com,https://api.example.com
# Use * to allow all origins (development only!)
# If unset, service rejects all external requests
# CORS_ORIGINS=*

# -----------------------------------------------------------------------------
# Coordinator URL (used by dashboard build and Discord bot)
# -----------------------------------------------------------------------------
# URL where the coordinator is accessible
# For remote coordinator: use Tailscale IP or domain
# For local development: leave unset or use http://localhost:3001
# COORDINATOR_URL=http://100.71.200.1:3001

# -----------------------------------------------------------------------------
# Database
# -----------------------------------------------------------------------------
# DATABASE_URL is auto-configured for Docker Compose (connects to postgres service)
# Only override if using an external database
# DATABASE_URL=

# PostgreSQL password (required for the postgres container)
# Generate a secure password, e.g.: openssl rand -base64 32
POSTGRES_PASSWORD=change_this_secure_password

# -----------------------------------------------------------------------------
# Redis
# -----------------------------------------------------------------------------
# REDIS_URL is auto-configured for Docker Compose (connects to redis service)
# Only override if using an external Redis instance
# REDIS_URL=

# -----------------------------------------------------------------------------
# Agent Configuration (Docker Compose manages agents automatically)
# -----------------------------------------------------------------------------
# Number of agent replicas to run (default: 3)
# AGENT_COUNT=3

# -----------------------------------------------------------------------------
# Debug Options
# -----------------------------------------------------------------------------
# Enable verbose Minecraft protocol logging
# MC_DEBUG=false

# -----------------------------------------------------------------------------
# Dashboard Configuration
# -----------------------------------------------------------------------------
# Port for the web dashboard (default: 8080)
# Dashboard is enabled by running: docker compose --profile dashboard up -d
# DASHBOARD_PORT=8080
